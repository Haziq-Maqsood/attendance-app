<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        >

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_student_item_image"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/user"
            app:civ_border_width="2dp"
            android:layout_gravity="center"
            app:civ_border_color="@color/primary_purple"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/cd_student_image" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_student_item_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: HM-100101"
                android:textColor="@color/primary_purple"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_student_item_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name: John Doe"
                android:textColor="@color/primary_text_color"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_student_item_father_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Father: Richard Doe"
                android:textColor="@color/secondary_text_color"
                android:textSize="14sp"
                android:layout_marginBottom="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <TextView
                    android:id="@+id/tv_student_item_age"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age: 18"
                    android:textColor="@color/secondary_text_color"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tv_student_item_admission_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admitted: 2024-07-09"
                    android:textColor="@color/secondary_text_color"
                    android:textSize="14sp"/>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary_text_color"
                android:text="Belt : "/>
            <TextView
                android:id="@+id/tv_student_item_belt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary_text_color"
                android:text="Belt  "/>
            </LinearLayout>


        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>